def pascal(row_number):
    number=1
    row=[0,1,0]
    new_row=[]
    triangle=[]
    while number <= row_number:
        index=0
        new_row=[]
        while index+1<len(row):
            if number==1:
                new_row=[1]
                break
            num=row[index]+row[index+1]
            new_row.append(num)
            index+=1
        elements=new_row.copy()
        triangle.append(elements)
        row=new_row
        row.insert(0,0)
        row.append(0)
        number+=1
    return triangle

def pascal_triangle(triangle: list):
    triangle_list=[]
    for items in triangle:
        string=""
        index=0
        for digits in items:
            if index!=len(items)-1:
                string+=str(digits)+" "
            else:
                string+=str(digits)
            index+=1
        triangle_list.append(string)
    mid_point=(len(triangle_list[-1]))//2
    median=triangle_list[-1][0:mid_point]
    median_length=len(median)
    for items in triangle_list:
        mid=(len(items))//2
        med=items[0:mid]
        median=len(med)
        print(f"{" "*(median_length-median)}{items}")
        
if __name__=="__main__":
    while True:
        row_number=int(input("Enter the number of rows of the triangle, enter 0 to finish: "))
        if row_number==0:
            break
        triangle_elements=pascal(row_number)
        pascal_triangle(triangle_elements)